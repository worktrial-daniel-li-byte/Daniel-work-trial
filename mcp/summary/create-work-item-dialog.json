{
  "title": "New task",
  "required_marker": "*",
  "actions": ["Minimize", "Go full screen", "Close", "Create", "Create another (checkbox)"],
  "fields": [
    { "name": "Space", "type": "combobox", "required": true, "default": "Autoloop (AUT)" },
    { "name": "Work type", "type": "combobox", "required": true, "examples": ["Task", "Workstream", "Sub-task", "Epic"] },
    { "name": "Status", "type": "combobox", "default": "To Do" },
    { "name": "Summary", "type": "textbox", "required": true },
    { "name": "Description", "type": "rich_text", "features": ["/ai to Ask Rovo", "@ to mention and notify"] },
    { "name": "Assignee", "type": "combobox", "helpers": ["Assign to me"] },
    { "name": "Priority", "type": "combobox" },
    { "name": "Labels", "type": "combobox_multi" },
    { "name": "Due date", "type": "date_picker" },
    { "name": "Attachment", "type": "file_upload", "action": "Browse attachment" },
    { "name": "Original estimate", "type": "duration_string", "placeholder": "2w 1d 5h 4m" },
    { "name": "Start date", "type": "date_picker" },
    { "name": "Category", "type": "combobox" },
    { "name": "Team", "type": "combobox" },
    { "name": "Budget", "type": "textbox" },
    { "name": "Linked work items", "type": "combobox", "link_types": ["Type, search or paste URL to link work items"] }
  ]
}
